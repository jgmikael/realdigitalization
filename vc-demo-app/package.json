    "did-resolver": "^4.1.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonld": "^8.3.1",
    "n3": "^1.17.1",
    "rdf-parse": "^2.3.2",
    "uuid": "^9.0.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
