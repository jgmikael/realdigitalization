        },
        "issueDate": {
          "@id": "unece:issueDateTime",
          "@type": "xsd:dateTime"
        },
        "declaredValueForCarriage": {
          "@id": "unece:declaredValueForCarriageAmount",
          "@type": "@id"
        },
        "declaredValueForCustoms": {
          "@id": "unece:declaredValueForCustomsAmount",
          "@type": "@id"
        },
        "insuranceValueAmount": {
          "@id": "unece:insuranceValueAmount",
          "@type": "@id"
        },
        "grossWeightMeasure": {
          "@id": "unece:grossWeightMeasure",
          "@type": "@id"
        },
        "grossVolumeMeasure": {
          "@id": "unece:grossVolumeMeasure",
          "@type": "@id"
        },
        "packageQuantity": {
