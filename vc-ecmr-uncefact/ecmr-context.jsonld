        "deliveryTerms": {
          "@id": "unece:applicableDeliveryTerms",
          "@type": "@id"
        },
        "transportMovement": {
          "@id": "unece:mainCarriageLogisticsTransportMovement",
          "@type": "@id"
        },
        "transportEquipment": {
          "@id": "unece:utilizedLogisticsTransportEquipment",
